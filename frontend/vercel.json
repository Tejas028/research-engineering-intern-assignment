{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://research-engineering-intern-assignment-production-c0a5.up.railway.app/api/$1"
    },
    {
      "source": "/static/(.*)",
      "destination": "https://research-engineering-intern-assignment-production-c0a5.up.railway.app/static/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
